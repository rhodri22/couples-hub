# Copy this to .env.local and fill in your values
# Get these from your Supabase project → Settings → API

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# A shared ID that ties both devices together (any string you like, e.g. "rhodri-becky-2025")
VITE_HOUSEHOLD_ID=rhodri-becky-hub

# Web Push (background notifications). Generate a key pair with:
#   npm install && npm run gen:vapid
# Put the PUBLIC key here (and the same value + the PRIVATE key in Vercel).
# Full setup: see PUSH_SETUP.md
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key

# Optional: gate the AI endpoint (voice / travel / assistant) behind a shared
# secret. Set the SAME value here and as AI_SHARED_SECRET in Vercel to enable it.
# Leave both blank to keep the endpoint open (rate-limited only). See SECURITY.md
# VITE_HUB_SECRET=your-shared-secret
